# Copy this file to .env and fill in the two required Notion values.
# Do not commit .env.

NOTION_TOKEN=secret_your_notion_integration_token
NOTION_DATABASE_URL=https://www.notion.so/your-workspace/your-meeting-database-id

# Optional: use this only if you want to sync one fixed page instead of
# automatically selecting the latest page from NOTION_DATABASE_URL.
NOTION_PAGE_URL=

# Optional settings
# Leave NOTION_OUTPUT_PATH empty to save as Scrum/yyyy-MM-dd.md.
NOTION_OUTPUT_PATH=
NOTION_DATE_PROPERTY=
GITHUB_REPO_URL=https://github.com/weeeeestern/2026-Software-Engineering.git
GIT_BRANCH=main
GIT_COMMIT_MESSAGE=Sync scrum meeting notes
